{
    "compilerOptions": {
      "module": "commonjs",
      "noImplicitAny": true,
      "outDir": "lib",
      "sourceMap": true,
      "strict": true,
      "strictNullChecks": true,
      "skipLibCheck": true,
      "target": "es2020",
      "rootDir": "..",
      "baseUrl": ".",
      "paths": {
        "@shared/*": [
          "../shared/*"
        ]
      }
    },
    "compileOnSave": true,
    "include": [
      "src"
    ]
  }